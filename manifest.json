{
  "manifest_version": 3,
  "name": "Mailtropy",
  "version": "0.1.0",
  "description": "Privacy-first Gmail insights with read-only metadata analytics.",
  "action": {
    "default_title": "Mailtropy",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": ["identity", "storage"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "oauth2": {
    "client_id": "810560848692-0r40a78s1k5d30vvjjlf1i60hm2uc4i9.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.readonly"]
  },
  "web_accessible_resources": [
    {
      "resources": ["privacy.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
